<header class="fixed top-0 w-full z-50 bg-[#ffffff] border-b border-stone-gray h-20 flex items-center">
  <nav class="w-full max-w-container-max mx-auto px-gutter flex justify-between items-center">
    <div class="flex items-center">
      <a class="font-headline-sm text-headline-sm text-legal-navy tracking-tight font-bold" href="/"><%= settings?.site_title || 'Av. Danışman' %></a>
    </div>
    <div class="hidden md:flex items-center space-x-8">
      <a class="font-nav-link text-nav-link text-on-surface-variant hover:text-prestige-gold transition-colors duration-200" href="/hakkimda">Hakkımda</a>
      <a class="font-nav-link text-nav-link text-on-surface-variant hover:text-prestige-gold transition-colors duration-200" href="/makaleler">Makaleler</a>
      <a class="font-nav-link text-nav-link text-on-surface-variant hover:text-prestige-gold transition-colors duration-200" href="/iletisim">İletişim</a>
      <a class="font-nav-link text-nav-link text-on-surface-variant hover:text-prestige-gold transition-colors duration-200" href="/kaynaklar">Kaynaklar</a>
    </div>
    <div class="flex items-center gap-4">
      <a class="px-6 py-2.5 bg-legal-navy text-paper-white font-nav-link text-nav-link hover:bg-opacity-90 transition-all rounded" href="/iletisim">Randevu Al</a>
      <button class="md:hidden text-legal-navy" id="mobileMenuBtn">
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile Navigation Drawer -->
<div class="fixed inset-0 bg-black bg-opacity-50 z-40 hidden" id="mobileMenuOverlay"></div>
<div class="fixed top-0 right-0 h-full w-64 bg-white z-50 transform translate-x-full transition-transform duration-300 ease-in-out border-l border-stone-gray" id="mobileMenuDrawer">
  <div class="h-20 flex items-center justify-between px-6 border-b border-stone-gray">
    <span class="font-headline-sm text-headline-sm text-legal-navy">Menü</span>
    <button class="text-legal-navy" id="mobileMenuCloseBtn">
      <span class="material-symbols-outlined">close</span>
    </button>
  </div>
  <div class="flex flex-col p-6 space-y-6">
    <a class="font-nav-link text-lg text-legal-navy hover:text-prestige-gold transition-colors" href="/hakkimda">Hakkımda</a>
    <a class="font-nav-link text-lg text-legal-navy hover:text-prestige-gold transition-colors" href="/makaleler">Makaleler</a>
    <a class="font-nav-link text-lg text-legal-navy hover:text-prestige-gold transition-colors" href="/iletisim">İletişim</a>
    <a class="font-nav-link text-lg text-legal-navy hover:text-prestige-gold transition-colors" href="/kaynaklar">Kaynaklar</a>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const menuBtn = document.getElementById('mobileMenuBtn');
    const closeBtn = document.getElementById('mobileMenuCloseBtn');
    const overlay = document.getElementById('mobileMenuOverlay');
    const drawer = document.getElementById('mobileMenuDrawer');

    if (menuBtn && closeBtn && overlay && drawer) {
      menuBtn.addEventListener('click', () => {
        overlay.classList.remove('hidden');
        drawer.classList.remove('translate-x-full');
      });

      const closeMenu = () => {
        overlay.classList.add('hidden');
        drawer.classList.add('translate-x-full');
      };

      closeBtn.addEventListener('click', closeMenu);
      overlay.addEventListener('click', closeMenu);
    }
  });
</script>
