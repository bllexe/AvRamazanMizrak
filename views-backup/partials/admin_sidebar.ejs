<!-- Toast Notification System -->
<div id="toast-container" class="fixed top-6 right-6 z-[9999] flex flex-col gap-3 pointer-events-none"></div>

<script>
  function showToast(message, type = 'success') {
    const container = document.getElementById('toast-container');
    if (!container) return;

    // Toast Element
    const toast = document.createElement('div');
    toast.className = `flex items-center gap-3 px-5 py-3.5 bg-white border rounded-xl shadow-xl transform translate-y-2 opacity-0 transition-all duration-300 ease-out pointer-events-auto max-w-sm`;
    
    // Icon & Colors based on type
    let icon = 'info';
    let iconClass = 'text-blue-500';
    let borderColor = 'border-stone-gray';
    
    if (type === 'success') {
      icon = 'check_circle';
      iconClass = 'text-emerald-500';
      borderColor = 'border-emerald-100';
    } else if (type === 'error') {
      icon = 'error';
      iconClass = 'text-red-500';
      borderColor = 'border-red-100';
    } else if (type === 'warning') {
      icon = 'warning';
      iconClass = 'text-amber-500';
      borderColor = 'border-amber-100';
    }

    toast.classList.add(borderColor);
    
    toast.innerHTML = `
      <span class="material-symbols-outlined ${iconClass} shrink-0">${icon}</span>
      <span class="text-xs font-semibold text-legal-navy">${message}</span>
      <button onclick="this.parentElement.remove()" class="text-on-surface-variant hover:text-legal-navy ml-auto shrink-0 flex items-center">
        <span class="material-symbols-outlined text-[16px]">close</span>
      </button>
    `;

    container.appendChild(toast);

    // Animate In
    setTimeout(() => {
      toast.classList.remove('translate-y-2', 'opacity-0');
      toast.classList.add('translate-y-0', 'opacity-100');
    }, 10);

    // Auto Remove after 4 seconds
    setTimeout(() => {
      toast.classList.remove('translate-y-0', 'opacity-100');
      toast.classList.add('translate-y-[-10px]', 'opacity-0');
      setTimeout(() => {
        toast.remove();
      }, 300);
    }, 4000);
  }

  // Check URL parameters for toast triggers on page load
  window.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    const toastType = urlParams.get('toast');
    
    if (toastType) {
      // Map toast types to messages
      const toastMessages = {
        'article_created': 'Makale başarıyla yayınlandı.',
        'article_updated': 'Makale başarıyla güncellendi.',
        'article_deleted': 'Makale başarıyla silindi.',
        'category_created': 'Kategori başarıyla oluşturuldu.',
        'category_updated': 'Kategori başarıyla güncellendi.',
        'category_deleted': 'Kategori başarıyla silindi.',
        'profile_updated': 'Profil bilgileri başarıyla güncellendi.',
        'settings_updated': 'Genel ayarlar başarıyla kaydedildi.',
        'message_read': 'Mesaj okundu olarak işaretlendi.',
        'message_deleted': 'Mesaj başarıyla silindi.',
        'resource_created': 'Kaynak başarıyla oluşturuldu.',
        'resource_updated': 'Kaynak başarıyla güncellendi.',
        'resource_deleted': 'Kaynak başarıyla silindi.',
        'error': 'Bir hata oluştu. Lütfen tekrar deneyin.'
      };

      const message = toastMessages[toastType];
      if (message) {
        // Show the toast
        showToast(message, toastType.includes('error') ? 'error' : 'success');
        
        // Clean URL parameter without reloading the page
        const cleanUrl = window.location.protocol + "//" + window.location.host + window.location.pathname;
        window.history.replaceState({ path: cleanUrl }, '', cleanUrl);
      }
    }
  });
</script>
