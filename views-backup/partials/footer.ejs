<footer class="bg-legal-navy text-white pt-20 pb-10 mt-auto">
  <div class="max-w-container-max mx-auto px-gutter grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
    <div class="col-span-1 md:col-span-2">
      <div class="font-headline-md text-headline-md text-prestige-gold mb-6">
        <%= settings?.site_title || 'Av. Danışman' %>
      </div>
      <p class="text-stone-gray opacity-80 max-w-sm mb-8">
        Profesyonel hukuk çözümleri ile adalete giden yolda yanınızdayız. Modern ve şeffaf hukuk danışmanlığı.
      </p>
      <div class="flex gap-4">
        <% if (locals.author?.linkedin_url) { %>
          <a class="w-10 h-10 rounded-full border border-stone-gray border-opacity-30 flex items-center justify-center hover:bg-prestige-gold hover:border-prestige-gold text-white hover:text-legal-navy transition-all" href="<%= locals.author.linkedin_url %>" target="_blank" title="LinkedIn">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          </a>
        <% } %>
        <% if (locals.author?.twitter_url) { %>
          <a class="w-10 h-10 rounded-full border border-stone-gray border-opacity-30 flex items-center justify-center hover:bg-prestige-gold hover:border-prestige-gold text-white hover:text-legal-navy transition-all" href="<%= locals.author.twitter_url %>" target="_blank" title="Twitter / X">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        <% } %>
        <% if (locals.author?.instagram_url) { %>
          <a class="w-10 h-10 rounded-full border border-stone-gray border-opacity-30 flex items-center justify-center hover:bg-prestige-gold hover:border-prestige-gold text-white hover:text-legal-navy transition-all" href="<%= locals.author.instagram_url %>" target="_blank" title="Instagram">
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        <% } %>
      </div>
    </div>
    <div>
      <h5 class="font-label-caps text-label-caps text-white mb-6 uppercase tracking-wider">Hızlı Linkler</h5>
      <ul class="space-y-4">
        <li><a class="text-stone-gray opacity-80 hover:text-prestige-gold transition-all" href="/hakkimda">Hakkımda</a></li>
        <li><a class="text-stone-gray opacity-80 hover:text-prestige-gold transition-all" href="/makaleler">Makaleler</a></li>
        <li><a class="text-stone-gray opacity-80 hover:text-prestige-gold transition-all" href="/iletisim">İletişim</a></li>
        <li><a class="text-stone-gray opacity-80 hover:text-prestige-gold transition-all" href="/kaynaklar">Kaynaklar</a></li>
      </ul>
    </div>
    <div>
      <h5 class="font-label-caps text-label-caps text-white mb-6 uppercase tracking-wider">Hukuki Bilgi</h5>
      <ul class="space-y-4">
        <li><a class="text-stone-gray opacity-80 hover:text-prestige-gold transition-all" href="/legal/kvkk">KVKK</a></li>
        <li><a class="text-stone-gray opacity-80 hover:text-prestige-gold transition-all" href="/legal/privacy">Gizlilik Politikası</a></li>
        <li><a class="text-stone-gray opacity-80 hover:text-prestige-gold transition-all" href="/legal/terms">Kullanım Koşulları</a></li>
      </ul>
    </div>
  </div>
  <div class="max-w-container-max mx-auto px-gutter border-t border-stone-gray border-opacity-10 pt-10 flex flex-col md:flex-row justify-between items-center gap-4 text-center">
    <p class="text-stone-gray opacity-80 text-body-md">© 2026 Tüm Hakları Saklıdır.</p>
    <p class="text-stone-gray opacity-50 text-[12px]">Bu sitede yer alan bilgiler hukuki tavsiye niteliği taşımayıp sadece bilgilendirme amaçlıdır.</p>
  </div>
</footer>

<!-- WhatsApp Floating Action -->
