<!DOCTYPE html>
<html class="light" lang="tr">
<head>
  <%- include('../partials/head', { title: 'Yönetici Girişi' }) %>
</head>
<body class="bg-background font-body-md text-on-surface antialiased flex items-center justify-center min-h-screen p-gutter bg-subtle-pattern">

  <div class="w-full max-w-md bg-white border border-stone-gray rounded-xl p-8 md:p-10 shadow-2xl space-y-6">
    <div class="text-center space-y-2">
      <span class="font-label-caps text-label-caps text-prestige-gold tracking-widest uppercase">Yönetim Paneli</span>
      <h1 class="font-headline-sm text-headline-sm text-legal-navy">Avukat Girişi</h1>
      <p class="text-sm text-on-surface-variant">Sitenizi yönetmek için bilgilerinizi giriniz.</p>
    </div>

    <% if (error) { %>
      <div class="bg-error-container text-error px-4 py-3 rounded text-sm font-semibold flex items-center gap-2">
        <span class="material-symbols-outlined text-[20px]">error</span>
        <%= error %>
      </div>
    <% } %>

    <form action="/admin/login" method="POST" class="space-y-6">
      <div class="space-y-2">
        <label class="font-label-caps text-xs text-on-surface-variant tracking-wider block" for="email">E-POSTA ADRESİ</label>
        <input class="w-full px-4 py-3 bg-[#FCFBFA] border border-[#DEDCD7] rounded-lg focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold hover:border-[#C4C1BA] transition-all outline-none text-sm" id="email" name="email" type="email" placeholder="admin@avdanisman.com" required value="admin@avdanisman.com"/>
      </div>
      <div class="space-y-2">
        <label class="font-label-caps text-xs text-on-surface-variant tracking-wider block" for="password">ŞİFRE</label>
        <input class="w-full px-4 py-3 bg-[#FCFBFA] border border-[#DEDCD7] rounded-lg focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold hover:border-[#C4C1BA] transition-all outline-none text-sm" id="password" name="password" type="password" placeholder="••••••••" required value="adminpassword"/>
      </div>
      
      <button class="w-full py-3.5 bg-legal-navy text-white font-bold rounded-lg hover:bg-opacity-95 transition-all flex items-center justify-center gap-2 group shadow-lg text-sm" type="submit">
        Giriş Yap
        <span class="material-symbols-outlined text-prestige-gold group-hover:translate-x-1 transition-transform text-[20px]">login</span>
      </button>
    </form>

    <div class="text-center pt-2">
      <a href="/" class="text-xs text-on-surface-variant hover:text-prestige-gold transition-colors flex items-center justify-center gap-1">
        <span class="material-symbols-outlined text-[16px]">arrow_back</span> Siteye Geri Dön
      </a>
    </div>
  </div>

</body>
</html>
