<!DOCTYPE html>
<html class="light" lang="tr">
<head>
  <%- include('../../partials/head', { title: 'Makale Düzenle' }) %>
  <!-- Quill Editor CSS -->
  <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
</head>
<body class="bg-background font-body-md text-on-surface antialiased overflow-hidden h-screen flex">

  <%- include('../../partials/admin_sidebar') %>

  <!-- Main Content Area -->
  <main class="flex-1 flex flex-col h-full overflow-hidden">
    <!-- Header -->
    <header class="h-20 bg-white border-b border-stone-gray flex items-center justify-between px-gutter shrink-0">
      <div>
        <h2 class="font-headline-sm text-headline-sm text-legal-navy">Makaleyi Düzenle</h2>
        <p class="text-nav-link text-on-surface-variant">Mevcut makalenizin içeriğini güncelleyin.</p>
      </div>
      <div>
        <a href="/admin/articles" class="border border-stone-gray px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-surface-container-low transition-colors">
          İptal Et
        </a>
      </div>
    </header>

    <!-- Form Content -->
    <div class="flex-1 overflow-y-auto p-gutter">
      <form action="/admin/articles/edit/<%= article.id %>" method="POST" id="articleForm" class="max-w-4xl bg-white border border-stone-gray rounded-xl p-8 shadow-sm space-y-6">
        
        <div class="space-y-2">
          <label class="font-label-caps text-xs text-on-surface-variant tracking-wider block" for="title">MAKALE BAŞLIĞI</label>
          <input class="w-full px-4 py-3 bg-[#FCFBFA] border border-[#DEDCD7] rounded-lg focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold hover:border-[#C4C1BA] transition-all outline-none text-sm" id="title" name="title" type="text" value="<%= article.title %>" required />
        </div>

        <div class="space-y-2">
          <label class="font-label-caps text-xs text-on-surface-variant tracking-wider block">KATEGORİLER (EN AZ BİR TANE SEÇİNİZ)</label>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4 bg-[#FCFBFA] border border-[#DEDCD7] rounded-lg p-4" id="categoryContainer">
            <% categories.forEach(cat => { %>
              <label class="flex items-center space-x-3 text-sm text-legal-navy cursor-pointer select-none">
                <input type="checkbox" name="category_ids" value="<%= cat.id %>" 
                       <%= (article.category_ids && article.category_ids.includes(cat.id)) || article.category_id === cat.id ? 'checked' : '' %>
                       class="rounded border-stone-gray text-prestige-gold focus:ring-prestige-gold w-4 h-4 cursor-pointer" />
                <span class="font-medium"><%= cat.name %></span>
              </label>
            <% }) %>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label class="font-label-caps text-xs text-on-surface-variant tracking-wider block" for="status">DURUM</label>
            <select class="w-full px-4 py-3 bg-[#FCFBFA] border border-[#DEDCD7] rounded-lg focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold outline-none text-sm" id="status" name="status" required>
              <option value="draft" <%= article.status === 'draft' ? 'selected' : '' %>>Taslak</option>
              <option value="published" <%= article.status === 'published' ? 'selected' : '' %>>Yayında</option>
            </select>
          </div>
        </div>

        <div class="space-y-2">
          <label class="font-label-caps text-xs text-on-surface-variant tracking-wider block" for="summary">ÖZET (MAX 150 KARAKTER)</label>
          <textarea class="w-full px-4 py-3 bg-[#FCFBFA] border border-[#DEDCD7] rounded-lg focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold hover:border-[#C4C1BA] transition-all outline-none resize-none text-sm" id="summary" name="summary" required rows="3" maxlength="150"><%= article.summary %></textarea>
        </div>

        <!-- Quill Rich Editor Container -->
        <div class="space-y-2">
          <label class="font-label-caps text-xs text-on-surface-variant tracking-wider block">MAKALE İÇERİĞİ</label>
          <div id="editor-container" class="h-80 bg-white border border-[#DEDCD7] rounded-lg"><%- article.content %></div>
          <!-- Hidden Input to store the HTML content -->
          <input type="hidden" name="content" id="hiddenContent">
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4">
          <div class="space-y-2">
            <label class="font-label-caps text-xs text-on-surface-variant tracking-wider block" for="meta_description">META AÇIKLAMASI (SEO)</label>
            <input class="w-full px-4 py-3 bg-[#FCFBFA] border border-[#DEDCD7] rounded-lg focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold hover:border-[#C4C1BA] transition-all outline-none text-sm" id="meta_description" name="meta_description" type="text" value="<%= article.meta_description %>" />
          </div>
          <div class="space-y-2">
            <label class="font-label-caps text-xs text-on-surface-variant tracking-wider block" for="meta_keywords">META ANAHTAR KELİMELERİ (SEO)</label>
            <input class="w-full px-4 py-3 bg-[#FCFBFA] border border-[#DEDCD7] rounded-lg focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold hover:border-[#C4C1BA] transition-all outline-none text-sm" id="meta_keywords" name="meta_keywords" type="text" value="<%= article.meta_keywords %>" />
          </div>
        </div>

        <div class="pt-6">
          <button class="w-full py-4 bg-legal-navy text-white font-bold rounded-lg hover:bg-opacity-95 transition-all flex items-center justify-center gap-2 group shadow-lg text-sm" type="submit">
            Değişiklikleri Kaydet
            <span class="material-symbols-outlined text-prestige-gold group-hover:translate-x-1 transition-transform text-[20px]">save</span>
          </button>
        </div>
      </form>
    </div>
  </main>

  <!-- Quill Rich Editor JS -->
  <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
  <script>
    var quill = new Quill('#editor-container', {
      theme: 'snow',
      modules: {
        toolbar: [
          [{ 'header': [1, 2, 3, false] }],
          ['bold', 'italic', 'underline', 'blockquote'],
          [{'list': 'ordered'}, {'list': 'bullet'}],
          ['link', 'clean']
        ]
      }
    });

    // Populate hidden input on submit
    var form = document.getElementById('articleForm');
    form.onsubmit = function() {
      // Validate that at least one category is checked
      var checkedCategories = form.querySelectorAll('input[name="category_ids"]:checked');
      if (checkedCategories.length === 0) {
        alert('Lütfen en az bir kategori seçiniz.');
        return false;
      }
      
      var contentInput = document.getElementById('hiddenContent');
      contentInput.value = quill.root.innerHTML;
      return true;
    };
  </script>
</body>
</html>
