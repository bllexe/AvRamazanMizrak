<!DOCTYPE html>
<html class="light" lang="tr">
<head>
  <%- include('../partials/head', { title: 'Kaynaklar - Yönetim' }) %>
</head>
<body class="bg-background font-body-md text-on-surface antialiased overflow-hidden h-screen flex">

  <%- include('../partials/admin_sidebar') %>

  <!-- Main Content Area -->
  <main class="flex-1 flex flex-col h-full overflow-hidden">
    <!-- Header -->
    <header class="h-20 bg-white border-b border-stone-gray flex items-center justify-between px-gutter shrink-0">
      <div>
        <h2 class="font-headline-sm text-headline-sm text-legal-navy">Kaynak & Doküman Yönetimi</h2>
        <p class="text-nav-link text-on-surface-variant">Sitenizdeki "Kaynaklar" sayfasında listelenen dosya ve şablonları yönetin.</p>
      </div>
    </header>

    <!-- Content -->
    <div class="flex-1 overflow-y-auto p-gutter">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter items-start">
        <!-- Resources List (2/3 width) -->
        <div class="lg:col-span-2 bg-white border border-stone-gray rounded shadow-[0_4px_20px_rgba(26,43,60,0.04)] overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left">
              <thead>
                <tr class="bg-surface-container-low text-on-surface-variant text-[11px] uppercase font-bold tracking-wider">
                  <th class="px-6 py-4 border-b border-stone-gray">Sıra</th>
                  <th class="px-6 py-4 border-b border-stone-gray">Başlık</th>
                  <th class="px-6 py-4 border-b border-stone-gray">Kategori</th>
                  <th class="px-6 py-4 border-b border-stone-gray">Tür</th>
                  <th class="px-6 py-4 border-b border-stone-gray">İndirilme / Görünüm</th>
                  <th class="px-6 py-4 border-b border-stone-gray text-right">İşlemler</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-stone-gray">
                <% if (resources && resources.length > 0) { %>
                  <% resources.forEach(res => { %>
                    <tr class="hover:bg-surface-container-low transition-colors">
                      <td class="px-6 py-4 text-xs font-semibold text-legal-navy"><%= res.display_order %></td>
                      <td class="px-6 py-4">
                        <div class="font-bold text-legal-navy text-sm"><%= res.title %></div>
                        <% if (res.description) { %>
                          <div class="text-xs text-on-surface-variant truncate max-w-xs mt-0.5"><%= res.description %></div>
                        <% } %>
                      </td>
                      <td class="px-6 py-4">
                        <span class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 bg-surface-container rounded text-legal-navy">
                          <%= res.category === 'guide' ? 'Kılavuz' : (res.category === 'template' ? 'Şablon' : 'Doküman') %>
                        </span>
                      </td>
                      <td class="px-6 py-4 text-xs text-on-surface-variant">
                        <% if (res.file_url) { %>
                          <span class="text-emerald-600 font-medium flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">download</span> Dosya
                          </span>
                        <% } else if (res.content) { %>
                          <span class="text-blue-600 font-medium flex items-center gap-1">
                            <span class="material-symbols-outlined text-[14px]">content_copy</span> Kopyalanabilir Metin
                          </span>
                        <% } else { %>
                          <span class="text-stone-400">Boş</span>
                        <% } %>
                      </td>
                      <td class="px-6 py-4 text-xs font-semibold text-legal-navy">
                        <%= res.download_count || 0 %>
                      </td>
                      <td class="px-6 py-4 text-right">
                        <div class="flex items-center justify-end gap-3">
                          <button type="button"
                                  data-id="<%= res.id %>"
                                  data-title="<%= res.title %>"
                                  data-category="<%= res.category %>"
                                  data-file-size="<%= res.file_size || '0' %>"
                                  data-display-order="<%= res.display_order %>"
                                  data-file-url="<%= res.file_url || '' %>"
                                  data-description="<%= res.description || '' %>"
                                  data-content="<%= res.content || '' %>"
                                  onclick="editResource(this)"
                                  class="text-legal-navy hover:text-prestige-gold transition-colors flex items-center" 
                                  title="Düzenle">
                            <span class="material-symbols-outlined text-[20px]">edit</span>
                          </button>
                          <form action="/admin/resources/delete/<%= res.id %>" method="POST" class="inline">
                            <button type="button" onclick="showDeleteModal(this.closest('form'), 'Kaynağı Sil', 'Bu kaynağı silmek istediğinize emin misiniz? Bu işlem geri alınamaz.')" class="text-error hover:bg-error-container p-1 rounded transition-colors flex items-center" title="Sil">
                              <span class="material-symbols-outlined text-[20px]">delete</span>
                            </button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="6" class="text-center py-12 text-on-surface-variant text-sm">Kaynak bulunmamaktadır.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Create / Edit Form Card (1/3 width) -->
        <div class="bg-white border border-stone-gray rounded p-6 shadow-[0_4px_20px_rgba(26,43,60,0.04)] space-y-6">
          <div>
            <h3 class="font-headline-sm text-lg text-legal-navy" id="formTitle">Yeni Kaynak Ekle</h3>
            <p class="text-xs text-on-surface-variant mt-1">İndirilebilir bir dosya yükleyin veya kopyalanabilir şablon metni girin.</p>
          </div>

          <form action="/admin/resources/create" method="POST" enctype="multipart/form-data" id="resourceForm" class="space-y-4">
            <!-- Preservation hidden fields for editing -->
            <input type="hidden" name="existing_file_url" id="existing_file_url" />
            <input type="hidden" name="existing_file_size" id="existing_file_size" />

            <div class="space-y-1">
              <label class="font-label-caps text-[10px] text-on-surface-variant tracking-wider block" for="title">KAYNAK BAŞLIĞI</label>
              <input class="w-full px-3 py-2 bg-[#FCFBFA] border border-[#DEDCD7] rounded focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold outline-none text-sm" id="title" name="title" type="text" placeholder="Örn: KVKK Uyum Kılavuzu" required />
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div class="space-y-1">
                <label class="font-label-caps text-[10px] text-on-surface-variant tracking-wider block" for="category">KATEGORİ</label>
                <select class="w-full px-3 py-2 bg-[#FCFBFA] border border-[#DEDCD7] rounded focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold outline-none text-sm" id="category" name="category" required>
                  <option value="guide">Kılavuz</option>
                  <option value="template">Şablon</option>
                  <option value="document">Doküman</option>
                </select>
              </div>

              <div class="space-y-1">
                <label class="font-label-caps text-[10px] text-on-surface-variant tracking-wider block" for="display_order">SIRA NO</label>
                <input class="w-full px-3 py-2 bg-[#FCFBFA] border border-[#DEDCD7] rounded focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold outline-none text-sm" id="display_order" name="display_order" type="number" value="0" required />
              </div>
            </div>

            <div class="space-y-1">
              <div class="flex items-center justify-between">
                <label class="font-label-caps text-[10px] text-on-surface-variant tracking-wider block" for="file">DOSYA YÜKLE (OPSİYONEL)</label>
                <div class="group relative flex items-center">
                  <span class="material-symbols-outlined text-[15px] text-prestige-gold cursor-help hover:text-opacity-80 transition-colors">info</span>
                  <div class="absolute right-0 bottom-full mb-2 w-48 p-2.5 bg-legal-navy text-white text-[10px] rounded shadow-lg opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity duration-200 z-10 leading-normal border border-stone-gray/20">
                    <strong class="text-prestige-gold">Dosya Yükleme Limitleri:</strong><br/>
                    • Tek dosya: maks. 10 MB<br/>
                    • Dosya adeti: maks. 10 adet
                  </div>
                </div>
              </div>
              <input class="w-full px-3 py-2 bg-[#FCFBFA] border border-[#DEDCD7] rounded outline-none text-sm file:mr-4 file:py-1 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-semibold file:bg-stone-gray file:text-legal-navy hover:file:bg-opacity-80" id="file" name="file" type="file" />
              <p class="text-[10px] text-on-surface-variant mt-0.5">Seçtiğiniz dosya otomatik olarak Supabase Storage'a yüklenir.</p>
              <div id="currentFileSection" class="text-xs text-on-surface-variant hidden mt-1">
                Mevcut Dosya: <a id="currentFileLink" href="#" target="_blank" class="text-prestige-gold hover:underline font-semibold">Dosyayı Gör</a>
              </div>
            </div>

            <div class="space-y-1">
              <label class="font-label-caps text-[10px] text-on-surface-variant tracking-wider block" for="content">KOPYALANABİLİR ŞABLON METNİ (OPSİYONEL)</label>
              <textarea class="w-full px-3 py-2 bg-[#FCFBFA] border border-[#DEDCD7] rounded focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold outline-none resize-y text-xs font-mono" id="content" name="content" rows="6" placeholder="Örn: Dilekçe şablonu içeriği..."></textarea>
              <p class="text-[10px] text-on-surface-variant">Kullanıcılar sitenizde bu metni tek tıkla kopyalayabilir.</p>
            </div>

            <div class="space-y-1">
              <label class="font-label-caps text-[10px] text-on-surface-variant tracking-wider block" for="description">KISA AÇIKLAMA (OPSİYONEL)</label>
              <textarea class="w-full px-3 py-2 bg-[#FCFBFA] border border-[#DEDCD7] rounded focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold outline-none resize-none text-sm" id="description" name="description" rows="2" placeholder="Kaynak hakkında kısa özet..."></textarea>
            </div>

            <div class="pt-2 flex flex-col gap-2">
              <button class="w-full py-2.5 bg-legal-navy text-white font-bold rounded hover:bg-opacity-95 transition-all text-xs" type="submit">
                Kaydet
              </button>
              <button type="button" id="cancelBtn" onclick="cancelEdit()" class="w-full py-2 bg-stone-gray text-legal-navy font-bold rounded hover:bg-opacity-90 transition-all text-xs hidden">
                İptal Et
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </main>

  <!-- Custom Delete Confirmation Modal -->
  <div id="deleteModal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-[#1A2B3C] bg-opacity-40 backdrop-blur-sm"></div>
    
    <!-- Modal Content -->
    <div class="relative bg-white rounded-xl shadow-xl border border-stone-gray max-w-sm w-full mx-4 overflow-hidden transform scale-95 opacity-0 transition-all duration-300 ease-out" id="deleteModalContent">
      <div class="p-6">
        <div class="flex items-start gap-4 mb-6">
          <div class="w-10 h-10 rounded-full bg-[#FDF2F2] flex items-center justify-center text-error shrink-0">
            <span class="material-symbols-outlined text-[24px]">warning</span>
          </div>
          <div>
            <h4 class="font-bold text-legal-navy text-sm" id="deleteModalTitle">Silme İşlemini Onayla</h4>
            <p class="text-xs text-on-surface-variant mt-1.5 leading-relaxed" id="deleteModalMessage">Bu ögeyi silmek istediğinize emin misiniz? Bu işlem geri alınamaz.</p>
          </div>
        </div>
        <div class="flex justify-end gap-3">
          <button onclick="closeDeleteModal()" class="px-4 py-2 bg-stone-gray hover:bg-opacity-90 text-legal-navy font-semibold text-xs rounded transition-colors">
            İptal
          </button>
          <button id="confirmDeleteBtn" class="px-4 py-2 bg-error hover:bg-opacity-95 text-white font-semibold text-xs rounded transition-colors">
            Evet, Sil
          </button>
        </div>
      </div>
    </div>
  </div>

  <script>
    function editResource(btn) {
      const id = btn.getAttribute('data-id');
      const title = btn.getAttribute('data-title');
      const category = btn.getAttribute('data-category');
      const fileSize = btn.getAttribute('data-file-size');
      const displayOrder = btn.getAttribute('data-display-order');
      const fileUrl = btn.getAttribute('data-file-url');
      const description = btn.getAttribute('data-description');
      const content = btn.getAttribute('data-content');

      document.getElementById('formTitle').innerText = 'Kaynağı Düzenle';
      document.getElementById('resourceForm').action = '/admin/resources/edit/' + id;
      document.getElementById('title').value = title;
      document.getElementById('category').value = category;
      document.getElementById('display_order').value = displayOrder;
      document.getElementById('description').value = description;
      document.getElementById('content').value = content;
      
      document.getElementById('existing_file_url').value = fileUrl;
      document.getElementById('existing_file_size').value = fileSize;
      
      const currentFileSection = document.getElementById('currentFileSection');
      const currentFileLink = document.getElementById('currentFileLink');
      if (fileUrl) {
        currentFileLink.href = fileUrl;
        currentFileSection.classList.remove('hidden');
      } else {
        currentFileSection.classList.add('hidden');
      }

      document.getElementById('cancelBtn').classList.remove('hidden');
    }

    function cancelEdit() {
      document.getElementById('formTitle').innerText = 'Yeni Kaynak Ekle';
      document.getElementById('resourceForm').action = '/admin/resources/create';
      document.getElementById('resourceForm').reset();
      document.getElementById('display_order').value = '0';
      document.getElementById('existing_file_url').value = '';
      document.getElementById('existing_file_size').value = '';
      document.getElementById('currentFileSection').classList.add('hidden');
      document.getElementById('cancelBtn').classList.add('hidden');
    }

    let formToSubmit = null;

    function showDeleteModal(formElement, title, message) {
      formToSubmit = formElement;
      if (title) document.getElementById('deleteModalTitle').innerText = title;
      if (message) document.getElementById('deleteModalMessage').innerText = message;
      
      const modal = document.getElementById('deleteModal');
      const content = document.getElementById('deleteModalContent');
      
      modal.classList.remove('hidden');
      setTimeout(() => {
        content.classList.remove('scale-95', 'opacity-0');
        content.classList.add('scale-100', 'opacity-100');
      }, 10);
    }

    function closeDeleteModal() {
      const content = document.getElementById('deleteModalContent');
      content.classList.remove('scale-100', 'opacity-100');
      content.classList.add('scale-95', 'opacity-0');
      
      setTimeout(() => {
        document.getElementById('deleteModal').classList.add('hidden');
        formToSubmit = null;
      }, 300);
    }

    document.getElementById('confirmDeleteBtn').addEventListener('click', () => {
      if (formToSubmit) {
        formToSubmit.submit();
      }
    });
  </script>
</body>
</html>
