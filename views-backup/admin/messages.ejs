<!DOCTYPE html>
<html class="light" lang="tr">
<head>
  <%- include('../partials/head', { title: 'Gelen Mesajlar' }) %>
</head>
<body class="bg-background font-body-md text-on-surface antialiased overflow-hidden h-screen flex">

  <%- include('../partials/admin_sidebar') %>

  <!-- Main Content Area -->
  <main class="flex-1 flex flex-col h-full overflow-hidden">
    <!-- Header -->
    <header class="h-20 bg-white border-b border-stone-gray flex items-center justify-between px-gutter shrink-0">
      <div>
        <h2 class="font-headline-sm text-headline-sm text-legal-navy">Gelen İletişim Mesajları</h2>
        <p class="text-nav-link text-on-surface-variant">Sitenizdeki formlardan gönderilen mesajları listeleyin.</p>
      </div>
    </header>

    <!-- Content -->
    <div class="flex-1 overflow-y-auto p-gutter">
      <section class="bg-white border border-stone-gray rounded shadow-[0_4px_20px_rgba(26,43,60,0.04)] overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="bg-surface-container-low text-on-surface-variant text-[11px] uppercase font-bold tracking-wider">
                <th class="px-6 py-4 border-b border-stone-gray">Gönderen</th>
                <th class="px-6 py-4 border-b border-stone-gray">İletişim Bilgileri</th>
                <th class="px-6 py-4 border-b border-stone-gray">Konu</th>
                <th class="px-6 py-4 border-b border-stone-gray">Mesaj Detayı</th>
                <th class="px-6 py-4 border-b border-stone-gray">Tarih</th>
                <th class="px-6 py-4 border-b border-stone-gray">Durum</th>
                <th class="px-6 py-4 border-b border-stone-gray text-right">İşlemler</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-stone-gray">
              <% if (messages && messages.length > 0) { %>
                <% messages.forEach(msg => { %>
                  <tr class="hover:bg-surface-container-low transition-colors <%= msg.status === 'new' ? 'bg-[#FCFAF2] font-semibold' : '' %>">
                    <td class="px-6 py-4 text-sm text-legal-navy"><%= msg.name %></td>
                    <td class="px-6 py-4 text-xs text-on-surface-variant space-y-1">
                      <div class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-[14px]">mail</span> <%= msg.email %>
                      </div>
                      <% if (msg.phone) { %>
                        <div class="flex items-center gap-1">
                          <span class="material-symbols-outlined text-[14px]">call</span> <%= msg.phone %>
                        </div>
                      <% } %>
                    </td>
                    <td class="px-6 py-4 text-xs text-legal-navy"><%= msg.subject %></td>
                    <td class="px-6 py-4 text-xs text-on-surface-variant max-w-xs truncate"><%= msg.message %></td>
                    <td class="px-6 py-4 text-xs text-on-surface-variant">
                      <%= new Date(msg.submitted_at).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                    </td>
                    <td class="px-6 py-4">
                      <% if (msg.status === 'new') { %>
                        <span class="bg-[#FCF6E5] text-[#8C6D15] px-2 py-0.5 rounded text-[10px] font-bold">Yeni</span>
                      <% } else { %>
                        <span class="bg-stone-gray text-legal-navy px-2 py-0.5 rounded text-[10px] font-medium">Okundu</span>
                      <% } %>
                    </td>
                    <td class="px-6 py-4 text-right">
                      <div class="flex items-center justify-end gap-3">
                        <% if (msg.status === 'new') { %>
                          <form action="/admin/messages/<%= msg.id %>/read" method="POST" class="inline">
                            <button type="submit" class="bg-legal-navy text-white px-3 py-1.5 rounded text-xs font-semibold hover:bg-opacity-90 transition-all">
                              Okundu İşaretle
                            </button>
                          </form>
                        <% } %>
                        <button onclick="confirmDeleteMessage('<%= msg.id %>')" class="text-error hover:bg-error-container p-1.5 rounded-lg transition-colors flex items-center justify-center" title="Mesajı Sil">
                          <span class="material-symbols-outlined text-[18px]">delete</span>
                        </button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="7" class="text-center py-12 text-on-surface-variant text-sm">Gelen mesaj bulunmamaktadır.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </main>

  <!-- Delete Message Confirmation Modal -->
  <div id="delete-msg-modal" class="fixed inset-0 z-[10000] flex items-center justify-center hidden">
    <div class="absolute inset-0 bg-[#1A2B3C] bg-opacity-40 backdrop-blur-sm"></div>
    <div class="bg-white rounded-xl shadow-xl border border-stone-gray p-6 max-w-sm w-full mx-4 relative z-10 transform transition-transform duration-300 scale-95">
      <div class="flex items-start gap-4">
        <div class="w-10 h-10 rounded-full bg-error-container flex items-center justify-center shrink-0">
          <span class="material-symbols-outlined text-error">warning</span>
        </div>
        <div>
          <h3 class="font-headline-sm text-[16px] text-legal-navy mb-1">Mesajı Sil</h3>
          <p class="text-xs text-on-surface-variant leading-relaxed">Bu iletişim mesajını silmek istediğinize emin misiniz? Bu işlem geri alınamaz.</p>
        </div>
      </div>
      <div class="mt-6 flex justify-end gap-3">
        <button onclick="closeDeleteMsgModal()" class="px-4 py-2 bg-stone-gray hover:bg-opacity-90 text-legal-navy text-xs font-semibold rounded-lg transition-colors">İptal</button>
        <form id="delete-msg-form" method="POST" class="inline">
          <button type="submit" class="px-4 py-2 bg-error hover:bg-opacity-90 text-white text-xs font-semibold rounded-lg transition-colors">Evet, Sil</button>
        </form>
      </div>
    </div>
  </div>

  <script>
    function confirmDeleteMessage(id) {
      const modal = document.getElementById('delete-msg-modal');
      const form = document.getElementById('delete-msg-form');
      form.action = `/admin/messages/delete/${id}`;
      modal.classList.remove('hidden');
    }
    
    function closeDeleteMsgModal() {
      const modal = document.getElementById('delete-msg-modal');
      modal.classList.add('hidden');
    }
  </script>

</body>
</html>
