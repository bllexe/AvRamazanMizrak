<!DOCTYPE html>
<html class="light" lang="tr">
<head>
  <%- include('../partials/head', { title: 'Admin Dashboard' }) %>
</head>
<body class="bg-background font-body-md text-on-surface antialiased overflow-hidden h-screen flex">

  <%- include('../partials/admin_sidebar') %>

  <!-- Main Content Area -->
  <main class="flex-1 flex flex-col h-full overflow-hidden">
    <!-- Header -->
    <header class="h-20 bg-white border-b border-stone-gray flex items-center justify-between px-gutter shrink-0">
      <div>
        <h2 class="font-headline-sm text-headline-sm text-legal-navy">Hoş Geldiniz</h2>
        <p class="text-nav-link text-on-surface-variant">İşte bugün neler olduğu hakkında bir özet.</p>
      </div>
      <div class="flex items-center gap-4">
        <a href="/admin/articles/create" class="bg-legal-navy text-white px-6 py-2.5 rounded-lg font-nav-link hover:bg-ink-black transition-all flex items-center text-sm font-semibold">
          <span class="material-symbols-outlined mr-2 text-[20px]">add</span>
          Yeni Makale
        </a>
      </div>
    </header>

    <!-- Scrollable Dashboard Content -->
    <div class="flex-1 overflow-y-auto p-gutter space-y-gutter">
      <!-- KPI Cards Grid -->
      <section class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
        <!-- Card 1 -->
        <div class="bg-white p-6 border border-stone-gray rounded shadow-[0_4px_20px_rgba(26,43,60,0.04)] transition-all hover:-translate-y-1">
          <div class="flex items-start justify-between mb-4">
            <div class="w-12 h-12 bg-surface-container-low flex items-center justify-center rounded">
              <span class="material-symbols-outlined text-legal-navy">group</span>
            </div>
            <span class="text-green-600 text-[12px] font-bold flex items-center">
              <span class="material-symbols-outlined text-[16px] mr-1">trending_up</span> Canlı
            </span>
          </div>
          <h3 class="text-on-surface-variant text-label-caps uppercase">Toplam Okunma</h3>
          <p class="font-headline-md text-headline-md text-legal-navy mt-1"><%= totalViews %></p>
        </div>
        <!-- Card 2 -->
        <div class="bg-white p-6 border border-stone-gray rounded shadow-[0_4px_20px_rgba(26,43,60,0.04)] transition-all hover:-translate-y-1">
          <div class="flex items-start justify-between mb-4">
            <div class="w-12 h-12 bg-surface-container-low flex items-center justify-center rounded">
              <span class="material-symbols-outlined text-prestige-gold">mail</span>
            </div>
            <span class="text-prestige-gold text-[12px] font-bold">Yeni</span>
          </div>
          <h3 class="text-on-surface-variant text-label-caps uppercase">Bekleyen Mesajlar</h3>
          <p class="font-headline-md text-headline-md text-legal-navy mt-1"><%= newMessagesCount %></p>
        </div>
        <!-- Card 3 -->
        <div class="bg-white p-6 border border-stone-gray rounded shadow-[0_4px_20px_rgba(26,43,60,0.04)] transition-all hover:-translate-y-1">
          <div class="flex items-start justify-between mb-4">
            <div class="w-12 h-12 bg-surface-container-low flex items-center justify-center rounded">
              <span class="material-symbols-outlined text-legal-navy">article</span>
            </div>
            <span class="text-on-surface-variant text-[12px] font-medium">Toplam</span>
          </div>
          <h3 class="text-on-surface-variant text-label-caps uppercase">Yayındaki Makaleler</h3>
          <p class="font-headline-md text-headline-md text-legal-navy mt-1"><%= publishedCount %></p>
        </div>
      </section>

      <!-- Middle Section: Chart & Recent Activity -->
      <section class="grid grid-cols-1 lg:grid-cols-3 gap-gutter">
        <!-- Visitor Chart (2/3 width) -->
        <div class="lg:col-span-2 bg-white border border-stone-gray rounded p-6 shadow-[0_4px_20px_rgba(26,43,60,0.04)]">
          <div class="flex items-center justify-between mb-8">
            <div>
              <h3 class="font-headline-sm text-[20px] text-legal-navy">Ziyaretçi Grafiği</h3>
              <p class="text-nav-link text-on-surface-variant">Son 7 günlük trafik analizi (Sayfa Görüntüleme)</p>
            </div>
          </div>
          
          <!-- SVG Chart -->
          <div class="h-64 w-full relative">
            <svg class="w-full h-full" viewBox="0 0 800 240" preserveAspectRatio="none">
              <!-- Grid lines -->
              <line stroke="#E2E8F0" stroke-width="1" x1="0" x2="800" y1="0" y2="0"></line>
              <line stroke="#E2E8F0" stroke-width="1" x1="0" x2="800" y1="60" y2="60"></line>
              <line stroke="#E2E8F0" stroke-width="1" x1="0" x2="800" y1="120" y2="120"></line>
              <line stroke="#E2E8F0" stroke-width="1" x1="0" x2="800" y1="180" y2="180"></line>
              <line stroke="#E2E8F0" stroke-width="1" x1="0" x2="800" y1="240" y2="240"></line>
              
              <!-- Draw path if views exist -->
              <% 
                const maxVal = Math.max(...chartData.map(d => d.views), 10);
                const points = chartData.map((d, index) => {
                  const x = (index / (chartData.length - 1)) * 800;
                  const y = 240 - (d.views / maxVal) * 200;
                  return { x, y };
                });
                const pathD = points.reduce((acc, p, i) => i === 0 ? `M ${p.x} ${p.y}` : `${acc} L ${p.x} ${p.y}`, '');
                const areaD = `${pathD} L 800 240 L 0 240 Z`;
              %>
              <path d="<%= areaD %>" fill="rgba(197, 160, 89, 0.05)"></path>
              <path d="<%= pathD %>" fill="none" stroke="#C5A059" stroke-width="3"></path>
              
              <% points.forEach(p => { %>
                <circle cx="<%= p.x %>" cy="<%= p.y %>" fill="#C5A059" r="5"></circle>
              <% }) %>
            </svg>
            <div class="flex justify-between mt-4 text-[12px] text-on-surface-variant font-medium">
              <% chartData.forEach(d => { %>
                <span><%= d.day %> (<%= d.views %>)</span>
              <% }) %>
            </div>
          </div>
        </div>

        <!-- Recent Messages Summary (1/3 width) -->
        <div class="bg-white border border-stone-gray rounded p-6 shadow-[0_4px_20px_rgba(26,43,60,0.04)] flex flex-col">
          <div class="flex items-center justify-between mb-6 shrink-0">
            <h3 class="font-headline-sm text-[20px] text-legal-navy">Son Mesajlar</h3>
            <a class="text-prestige-gold text-nav-link hover:underline text-sm font-semibold" href="/admin/messages">Tümü</a>
          </div>
          <div class="space-y-6 overflow-y-auto flex-1 pr-1">
            <% if (recentMessages && recentMessages.length > 0) { %>
              <% recentMessages.forEach(msg => { %>
                <div class="flex items-start gap-3 border-b border-stone-gray/40 pb-3 last:border-0 last:pb-0">
                  <div class="w-10 h-10 bg-surface-container rounded-full flex-shrink-0 flex items-center justify-center font-bold text-legal-navy text-sm uppercase">
                    <%= (msg.name || 'AA').substring(0,2) %>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex justify-between items-baseline mb-1">
                      <p class="text-[14px] font-bold text-legal-navy truncate"><%= msg.name %></p>
                      <span class="text-[10px] text-on-surface-variant shrink-0">
                        <%= new Date(msg.submitted_at).toLocaleDateString('tr-TR', { hour: '2-digit', minute: '2-digit' }) %>
                      </span>
                    </div>
                    <p class="text-[12px] text-on-surface-variant font-medium truncate"><%= msg.subject %></p>
                    <p class="text-[13px] text-on-surface-variant line-clamp-2 mt-1"><%= msg.message %></p>
                  </div>
                </div>
              <% }) %>
            <% } else { %>
              <div class="text-center py-12 text-on-surface-variant text-sm">Mesaj bulunmamaktadır.</div>
            <% } %>
          </div>
        </div>
      </section>

      <!-- Bottom Table Section -->
      <section class="bg-white border border-stone-gray rounded shadow-[0_4px_20px_rgba(26,43,60,0.04)] overflow-hidden">
        <div class="p-6 border-b border-stone-gray flex justify-between items-center">
          <h3 class="font-headline-sm text-[20px] text-legal-navy">Son Eklenen Makaleler</h3>
          <a href="/admin/articles" class="border border-stone-gray px-4 py-2 rounded text-sm font-medium hover:bg-surface-container-low transition-colors">Tümünü Yönet</a>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="bg-surface-container-low text-on-surface-variant text-[11px] uppercase font-bold tracking-wider">
                <th class="px-6 py-4 border-b border-stone-gray">Başlık</th>
                <th class="px-6 py-4 border-b border-stone-gray">Kategori</th>
                <th class="px-6 py-4 border-b border-stone-gray">Oluşturma Tarihi</th>
                <th class="px-6 py-4 border-b border-stone-gray">Okunma</th>
                <th class="px-6 py-4 border-b border-stone-gray">Durum</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-stone-gray">
              <% if (recentArticles && recentArticles.length > 0) { %>
                <% recentArticles.forEach(art => { %>
                  <tr class="hover:bg-surface-container-low transition-colors">
                    <td class="px-6 py-4">
                      <div class="font-medium text-legal-navy text-sm"><%= art.title %></div>
                    </td>
                    <td class="px-6 py-4">
                      <span class="bg-stone-gray px-2 py-1 rounded text-[10px] font-bold text-legal-navy"><%= art.categoryName %></span>
                    </td>
                    <td class="px-6 py-4 text-xs text-on-surface-variant">
                      <%= new Date(art.created_at).toLocaleDateString('tr-TR') %>
                    </td>
                    <td class="px-6 py-4 text-xs text-on-surface-variant">
                      <%= art.view_count || 0 %>
                    </td>
                    <td class="px-6 py-4">
                      <% if (art.status === 'published') { %>
                        <span class="flex items-center text-[11px] text-green-700 font-semibold">
                          <span class="w-1.5 h-1.5 bg-green-500 rounded-full mr-1.5 animate-pulse"></span> Yayında
                        </span>
                      <% } else { %>
                        <span class="flex items-center text-[11px] text-prestige-gold font-semibold">
                          <span class="w-1.5 h-1.5 bg-prestige-gold rounded-full mr-1.5"></span> Taslak
                        </span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="5" class="text-center py-8 text-on-surface-variant text-sm">Makale bulunmamaktadır.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </main>

</body>
</html>
