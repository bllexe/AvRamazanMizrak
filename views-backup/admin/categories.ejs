<!DOCTYPE html>
<html class="light" lang="tr">
<head>
  <%- include('../partials/head', { title: 'Kategoriler - Yönetim' }) %>
</head>
<body class="bg-background font-body-md text-on-surface antialiased overflow-hidden h-screen flex">

  <%- include('../partials/admin_sidebar') %>

  <!-- Main Content Area -->
  <main class="flex-1 flex flex-col h-full overflow-hidden">
    <!-- Header -->
    <header class="h-20 bg-white border-b border-stone-gray flex items-center justify-between px-gutter shrink-0">
      <div>
        <h2 class="font-headline-sm text-headline-sm text-legal-navy">Makale Kategorileri</h2>
        <p class="text-nav-link text-on-surface-variant">Makalelerinizi gruplandırmak için kategorileri yönetin.</p>
      </div>
    </header>

    <!-- Content -->
    <div class="flex-1 overflow-y-auto p-gutter">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-gutter items-start">
        <!-- Categories List (2/3 width) -->
        <div class="lg:col-span-2 bg-white border border-stone-gray rounded shadow-[0_4px_20px_rgba(26,43,60,0.04)] overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left">
              <thead>
                <tr class="bg-surface-container-low text-on-surface-variant text-[11px] uppercase font-bold tracking-wider">
                  <th class="px-6 py-4 border-b border-stone-gray">Sıra</th>
                  <th class="px-6 py-4 border-b border-stone-gray">Kategori Adı</th>
                  <th class="px-6 py-4 border-b border-stone-gray">Slug / URL</th>
                  <th class="px-6 py-4 border-b border-stone-gray">Açıklama</th>
                  <th class="px-6 py-4 border-b border-stone-gray text-right">İşlemler</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-stone-gray">
                <% if (categories && categories.length > 0) { %>
                  <% categories.forEach(cat => { %>
                    <tr class="hover:bg-surface-container-low transition-colors">
                      <td class="px-6 py-4 text-xs font-semibold text-legal-navy"><%= cat.order_index %></td>
                      <td class="px-6 py-4 text-sm font-bold text-legal-navy"><%= cat.name %></td>
                      <td class="px-6 py-4 text-xs text-on-surface-variant"><%= cat.slug %></td>
                      <td class="px-6 py-4 text-xs text-on-surface-variant max-w-xs truncate"><%= cat.description %></td>
                      <td class="px-6 py-4 text-right">
                        <div class="flex items-center justify-end gap-3">
                          <button onclick="editCategory('<%= cat.id %>', '<%= cat.name %>', '<%= cat.slug %>', '<%= cat.description %>', '<%= cat.order_index %>')" class="text-legal-navy hover:text-prestige-gold transition-colors flex items-center">
                            <span class="material-symbols-outlined text-[20px]">edit</span>
                          </button>
                          <form action="/admin/categories/delete/<%= cat.id %>" method="POST" class="inline">
                            <button type="button" onclick="showDeleteModal(this.closest('form'), 'Kategoriyi Sil', 'Bu kategoriyi silmek istediğinize emin misiniz? Kategorideki makaleler kategorisiz kalacaktır.')" class="text-error hover:bg-error-container p-1 rounded transition-colors flex items-center">
                              <span class="material-symbols-outlined text-[20px]">delete</span>
                            </button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="5" class="text-center py-12 text-on-surface-variant text-sm">Kategori bulunmamaktadır.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Create / Edit Form Card (1/3 width) -->
        <div class="bg-white border border-stone-gray rounded p-6 shadow-[0_4px_20px_rgba(26,43,60,0.04)] space-y-6">
          <div>
            <h3 class="font-headline-sm text-lg text-legal-navy" id="formTitle">Yeni Kategori Ekle</h3>
            <p class="text-xs text-on-surface-variant mt-1">Gerekli alanları doldurarak kaydediniz.</p>
          </div>

          <form action="/admin/categories/create" method="POST" id="catForm" class="space-y-4">
            <div class="space-y-1">
              <label class="font-label-caps text-[10px] text-on-surface-variant tracking-wider block" for="name">KATEGORİ ADI</label>
              <input class="w-full px-3 py-2 bg-[#FCFBFA] border border-[#DEDCD7] rounded focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold outline-none text-sm" id="name" name="name" type="text" placeholder="Örn: Ceza Hukuku" required />
            </div>

            <div class="space-y-1">
              <label class="font-label-caps text-[10px] text-on-surface-variant tracking-wider block" for="slug">SLUG / URL (OPSİYONEL)</label>
              <input class="w-full px-3 py-2 bg-[#FCFBFA] border border-[#DEDCD7] rounded focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold outline-none text-sm" id="slug" name="slug" type="text" placeholder="Orn: ceza-hukuku" />
            </div>

            <div class="space-y-1">
              <label class="font-label-caps text-[10px] text-on-surface-variant tracking-wider block" for="order_index">SIRA NO</label>
              <input class="w-full px-3 py-2 bg-[#FCFBFA] border border-[#DEDCD7] rounded focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold outline-none text-sm" id="order_index" name="order_index" type="number" value="0" required />
            </div>

            <div class="space-y-1">
              <label class="font-label-caps text-[10px] text-on-surface-variant tracking-wider block" for="description">AÇIKLAMA (OPSİYONEL)</label>
              <textarea class="w-full px-3 py-2 bg-[#FCFBFA] border border-[#DEDCD7] rounded focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold outline-none resize-none text-sm" id="description" name="description" rows="3" placeholder="Kategori açıklaması..."></textarea>
            </div>

            <div class="pt-2 flex flex-col gap-2">
              <button class="w-full py-2.5 bg-legal-navy text-white font-bold rounded hover:bg-opacity-95 transition-all text-xs" type="submit">
                Kaydet
              </button>
              <button type="button" id="cancelBtn" onclick="cancelEdit()" class="w-full py-2 bg-stone-gray text-legal-navy font-bold rounded hover:bg-opacity-90 transition-all text-xs hidden">
                İptal Et
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </main>

  <!-- Custom Delete Confirmation Modal -->
  <div id="deleteModal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-[#1A2B3C] bg-opacity-40 backdrop-blur-sm"></div>
    
    <!-- Modal Content -->
    <div class="relative bg-white rounded-xl shadow-xl border border-stone-gray max-w-sm w-full mx-4 overflow-hidden transform scale-95 opacity-0 transition-all duration-300 ease-out" id="deleteModalContent">
      <div class="p-6">
        <div class="flex items-start gap-4 mb-6">
          <div class="w-10 h-10 rounded-full bg-[#FDF2F2] flex items-center justify-center text-error shrink-0">
            <span class="material-symbols-outlined text-[24px]">warning</span>
          </div>
          <div>
            <h4 class="font-bold text-legal-navy text-sm" id="deleteModalTitle">Silme İşlemini Onayla</h4>
            <p class="text-xs text-on-surface-variant mt-1.5 leading-relaxed" id="deleteModalMessage">Bu ögeyi silmek istediğinize emin misiniz? Bu işlem geri alınamaz.</p>
          </div>
        </div>
        <div class="flex justify-end gap-3">
          <button onclick="closeDeleteModal()" class="px-4 py-2 bg-stone-gray hover:bg-opacity-90 text-legal-navy font-semibold text-xs rounded transition-colors">
            İptal
          </button>
          <button id="confirmDeleteBtn" class="px-4 py-2 bg-error hover:bg-opacity-95 text-white font-semibold text-xs rounded transition-colors">
            Evet, Sil
          </button>
        </div>
      </div>
    </div>
  </div>

  <script>
    function editCategory(id, name, slug, description, orderIndex) {
      document.getElementById('formTitle').innerText = 'Kategoriyi Düzenle';
      document.getElementById('catForm').action = '/admin/categories/edit/' + id;
      document.getElementById('name').value = name;
      document.getElementById('slug').value = slug;
      document.getElementById('description').value = description;
      document.getElementById('order_index').value = orderIndex;
      document.getElementById('cancelBtn').classList.remove('hidden');
    }

    function cancelEdit() {
      document.getElementById('formTitle').innerText = 'Yeni Kategori Ekle';
      document.getElementById('catForm').action = '/admin/categories/create';
      document.getElementById('catForm').reset();
      document.getElementById('order_index').value = '0';
      document.getElementById('cancelBtn').classList.add('hidden');
    }

    let formToSubmit = null;

    function showDeleteModal(formElement, title, message) {
      formToSubmit = formElement;
      if (title) document.getElementById('deleteModalTitle').innerText = title;
      if (message) document.getElementById('deleteModalMessage').innerText = message;
      
      const modal = document.getElementById('deleteModal');
      const content = document.getElementById('deleteModalContent');
      
      modal.classList.remove('hidden');
      setTimeout(() => {
        content.classList.remove('scale-95', 'opacity-0');
        content.classList.add('scale-100', 'opacity-100');
      }, 10);
    }

    function closeDeleteModal() {
      const content = document.getElementById('deleteModalContent');
      content.classList.remove('scale-100', 'opacity-100');
      content.classList.add('scale-95', 'opacity-0');
      
      setTimeout(() => {
        document.getElementById('deleteModal').classList.add('hidden');
        formToSubmit = null;
      }, 300);
    }

    document.getElementById('confirmDeleteBtn').addEventListener('click', () => {
      if (formToSubmit) {
        formToSubmit.submit();
      }
    });
  </script>
</body>
</html>
