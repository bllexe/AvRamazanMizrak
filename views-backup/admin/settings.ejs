<!DOCTYPE html>
<html class="light" lang="tr">
<head>
  <%- include('../partials/head', { title: 'Site Ayarları' }) %>
</head>
<body class="bg-background font-body-md text-on-surface antialiased overflow-hidden h-screen flex">

  <%- include('../partials/admin_sidebar') %>

  <!-- Main Content Area -->
  <main class="flex-1 flex flex-col h-full overflow-hidden">
    <!-- Header -->
    <header class="h-20 bg-white border-b border-stone-gray flex items-center justify-between px-gutter shrink-0">
      <div>
        <h2 class="font-headline-sm text-headline-sm text-legal-navy">Genel Site Ayarları</h2>
        <p class="text-nav-link text-on-surface-variant">Web sitenizin genel başlık, açıklama, adres ve hukuki belgelerini düzenleyin.</p>
      </div>
    </header>

    <!-- Form Content -->
    <div class="flex-1 overflow-y-auto p-gutter pb-16">
      <form action="/admin/settings" method="POST" class="max-w-4xl bg-white border border-stone-gray rounded-xl p-8 shadow-sm space-y-6">
        
        <div class="space-y-2">
          <label class="font-label-caps text-xs text-on-surface-variant tracking-wider block" for="site_title">WEB SİTE BAŞLIĞI</label>
          <input class="w-full px-4 py-3 bg-[#FCFBFA] border border-[#DEDCD7] rounded-lg focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold outline-none text-sm" id="site_title" name="site_title" type="text" value="<%= settings?.site_title %>" required />
        </div>

        <div class="space-y-2">
          <label class="font-label-caps text-xs text-on-surface-variant tracking-wider block" for="site_description">SİTE AÇIKLAMASI (SEO VE META AÇIKLAMA GÖSTERİMİ)</label>
          <textarea class="w-full px-4 py-3 bg-[#FCFBFA] border border-[#DEDCD7] rounded-lg focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold outline-none resize-none text-sm" id="site_description" name="site_description" required rows="4"><%= settings?.site_description %></textarea>
        </div>

        <div class="space-y-2">
          <label class="font-label-caps text-xs text-on-surface-variant tracking-wider block" for="office_address">HUKUK BÜROSU ADRESİ</label>
          <textarea class="w-full px-4 py-3 bg-[#FCFBFA] border border-[#DEDCD7] rounded-lg focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold outline-none resize-none text-sm" id="office_address" name="office_address" required rows="3"><%= settings?.office_address %></textarea>
        </div>

        <!-- Hukuki Belgeler (KVKK, Gizlilik Politikası, Kullanım Koşulları) -->
        <div class="space-y-6 border-t border-stone-gray pt-6">
          <h3 class="font-headline-sm text-lg text-legal-navy">Hukuki Belgeler</h3>
          
          <div class="space-y-2">
            <label class="font-label-caps text-xs text-on-surface-variant tracking-wider block" for="kvkk">KVKK METNİ</label>
            <textarea class="w-full px-4 py-3 bg-[#FCFBFA] border border-[#DEDCD7] rounded-lg focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold outline-none resize-y text-sm font-sans" id="kvkk" name="kvkk" rows="8" placeholder="Kişisel Verilerin Korunması Kanunu aydınlatma metni..."><%= kvkk %></textarea>
          </div>

          <div class="space-y-2">
            <label class="font-label-caps text-xs text-on-surface-variant tracking-wider block" for="privacy">GİZLİLİK POLİTİKASI</label>
            <textarea class="w-full px-4 py-3 bg-[#FCFBFA] border border-[#DEDCD7] rounded-lg focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold outline-none resize-y text-sm font-sans" id="privacy" name="privacy" rows="8" placeholder="Gizlilik politikası metni..."><%= privacy %></textarea>
          </div>

          <div class="space-y-2">
            <label class="font-label-caps text-xs text-on-surface-variant tracking-wider block" for="terms">KULLANIM KOŞULLARI</label>
            <textarea class="w-full px-4 py-3 bg-[#FCFBFA] border border-[#DEDCD7] rounded-lg focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold outline-none resize-y text-sm font-sans" id="terms" name="terms" rows="8" placeholder="Kullanım koşulları metni..."><%= terms %></textarea>
          </div>
        </div>

        <div class="pt-6">
          <button class="w-full py-4 bg-legal-navy text-white font-bold rounded-lg hover:bg-opacity-95 transition-all flex items-center justify-center gap-2 group shadow-lg text-sm uppercase tracking-wider" type="submit">
            Ayarları Güncelle
            <span class="material-symbols-outlined text-prestige-gold group-hover:translate-x-1 transition-transform text-[20px]">save</span>
          </button>
        </div>
      </form>
    </div>
  </main>

</body>
</html>
