<!DOCTYPE html>
<html class="scroll-smooth" lang="tr">
<head>
  <%- include('../partials/head', { title: 'Makaleler' }) %>
</head>
<body class="bg-background text-on-background font-body-md selection:bg-prestige-gold selection:text-white flex flex-col min-h-screen">
  
  <%- include('../partials/header') %>

  <main class="pt-20 flex-1">
    <!-- Page Header -->
    <section class="pt-12 pb-8 bg-white">
      <div class="max-w-container-max mx-auto px-gutter">
        <nav class="flex items-center space-x-2 text-stone-gray font-label-caps text-label-caps mb-6">
          <a class="hover:text-legal-navy transition-colors" href="/">Anasayfa</a>
          <span class="material-symbols-outlined text-[14px]">chevron_right</span>
          <span class="text-legal-navy">Makaleler</span>
        </nav>
        <div class="max-w-2xl">
          <span class="font-label-caps text-label-caps text-prestige-gold block mb-2">BİLGİ PAYLAŞTIKÇA ÇOĞALIR</span>
          <h1 class="font-display-lg text-display-lg text-legal-navy mb-4">Hukuki Makaleler & Analizler</h1>
          <p class="font-body-lg text-body-lg text-on-surface-variant">Güncel yasal düzenlemeler, mahkeme kararları ve sektörel analizler ile haklarınızı daha iyi tanıyın.</p>
        </div>
      </div>
    </section>

    <!-- Filters Section -->
    <section class="py-6 bg-white border-t border-b border-stone-gray/60">
      <div class="max-w-container-max mx-auto px-gutter flex flex-col lg:flex-row justify-between gap-6 items-center">
        <!-- Category filters -->
        <div class="flex flex-wrap gap-2 justify-center lg:justify-start w-full lg:w-auto">
          <button onclick="filterCategory('all')" class="px-4 py-2 text-xs font-bold rounded-lg border transition-all <%= !activeCategory ? 'bg-legal-navy text-white border-legal-navy' : 'bg-background border-stone-gray text-legal-navy hover:border-prestige-gold' %>">
            TÜMÜ
          </button>
          <% categories.forEach(cat => { %>
            <button onclick="filterCategory('<%= cat.slug %>')" class="px-4 py-2 text-xs font-bold rounded-lg border transition-all <%= activeCategory && activeCategory.id === cat.id ? 'bg-legal-navy text-white border-legal-navy' : 'bg-background border-stone-gray text-legal-navy hover:border-prestige-gold' %>">
              <%= cat.name.toUpperCase() %>
            </button>
          <% }) %>
        </div>

        <!-- Search and Sort -->
        <div class="flex flex-col sm:flex-row gap-4 w-full lg:w-auto shrink-0">
          <div class="relative flex-1 sm:w-64">
            <input id="searchInput" type="text" placeholder="Makale ara..." value="<%= search %>" onkeyup="if(event.key==='Enter') searchArticles()" class="w-full pl-10 pr-4 py-2.5 bg-background border border-stone-gray rounded-lg focus:ring-1 focus:ring-prestige-gold focus:border-prestige-gold outline-none text-sm"/>
            <span class="material-symbols-outlined absolute left-3 top-3 text-on-surface-variant text-[20px]">search</span>
          </div>
          <select id="sortSelect" onchange="sortArticles()" class="bg-background border border-stone-gray rounded-lg px-4 py-2.5 text-sm focus:ring-1 focus:ring-prestige-gold outline-none">
            <option value="newest" <%= sortBy === 'newest' ? 'selected' : '' %>>En Yeni</option>
            <option value="oldest" <%= sortBy === 'oldest' ? 'selected' : '' %>>En Eski</option>
            <option value="popular" <%= sortBy === 'popular' ? 'selected' : '' %>>En Popüler</option>
          </select>
        </div>
      </div>
    </section>

    <!-- Articles Grid Section -->
    <section class="py-section-gap">
      <div class="max-w-container-max mx-auto px-gutter">
        <% if (articles && articles.length > 0) { %>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% articles.forEach(art => { %>
              <a class="group bg-white border border-stone-gray/20 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col rounded overflow-hidden" href="/makaleler/<%= art.slug %>">

                <div class="p-6 flex-1 flex flex-col">
                  <span class="font-label-caps text-label-caps text-prestige-gold mb-3 block uppercase">
                    <%= art.categories && art.categories.length > 0 ? art.categories.map(c => c.name).join(' / ') : 'Genel' %>
                  </span>
                  <h3 class="font-headline-sm text-[20px] text-legal-navy group-hover:text-prestige-gold transition-colors leading-snug mb-4"><%= art.title %></h3>
                  <p class="text-on-surface-variant text-body-md line-clamp-3 mb-6 flex-1"><%= art.summary %></p>
                  <div class="flex justify-between items-center text-xs text-on-surface-variant border-t border-stone-gray/30 pt-4 mt-auto">
                    <span class="flex items-center gap-1">
                      <span class="material-symbols-outlined text-[14px]">calendar_today</span>
                      <%= new Date(art.published_at || art.created_at).toLocaleDateString('tr-TR', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                    </span>
                    <span class="flex items-center gap-1">
                      <span class="material-symbols-outlined text-[14px]">schedule</span>
                      <%= art.reading_time_minutes %> dk okuma
                    </span>
                  </div>
                </div>
              </a>
            <% }) %>
          </div>

          <!-- Pagination -->
          <% if (totalPages > 1) { %>
            <div class="flex justify-center items-center gap-2 mt-16">
              <% if (page > 1) { %>
                <button onclick="navigatePage(<%= page - 1 %>)" class="w-10 h-10 border border-stone-gray rounded flex items-center justify-center hover:border-prestige-gold text-legal-navy">
                  <span class="material-symbols-outlined">chevron_left</span>
                </button>
              <% } %>
              
              <% for(let i = 1; i <= totalPages; i++) { %>
                <button onclick="navigatePage(<%= i %>)" class="w-10 h-10 border rounded flex items-center justify-center font-bold text-sm transition-colors <%= page === i ? 'bg-legal-navy text-white border-legal-navy' : 'border-stone-gray text-legal-navy hover:border-prestige-gold' %>">
                  <%= i %>
                </button>
              <% } %>

              <% if (page < totalPages) { %>
                <button onclick="navigatePage(<%= page + 1 %>)" class="w-10 h-10 border border-stone-gray rounded flex items-center justify-center hover:border-prestige-gold text-legal-navy">
                  <span class="material-symbols-outlined">chevron_right</span>
                </button>
              <% } %>
            </div>
          <% } %>

        <% } else { %>
          <div class="text-center py-20 bg-white border border-stone-gray rounded-xl">
            <span class="material-symbols-outlined text-5xl text-stone-gray mb-4">search_off</span>
            <h3 class="font-headline-sm text-legal-navy text-xl">Makale Bulunamadı</h3>
            <p class="text-on-surface-variant mt-2">Arama kriterlerinize uygun makale bulunmamaktadır. Lütfen farklı kelimelerle arama yapın.</p>
          </div>
        <% } %>
      </div>
    </section>
  </main>

  <%- include('../partials/footer') %>

  <script>
    function updateUrlParams(params) {
      const url = new URL(window.location.href);
      Object.keys(params).forEach(key => {
        if (params[key] === null || params[key] === undefined || params[key] === '') {
          url.searchParams.delete(key);
        } else {
          url.searchParams.set(key, params[key]);
        }
      });
      window.location.href = url.toString();
    }

    function filterCategory(catSlug) {
      updateUrlParams({ category: catSlug === 'all' ? '' : catSlug, page: 1 });
    }

    function searchArticles() {
      const val = document.getElementById('searchInput').value;
      updateUrlParams({ search: val, page: 1 });
    }

    function sortArticles() {
      const val = document.getElementById('sortSelect').value;
      updateUrlParams({ sortBy: val, page: 1 });
    }

    function navigatePage(pageNum) {
      updateUrlParams({ page: pageNum });
    }
  </script>
</body>
</html>
