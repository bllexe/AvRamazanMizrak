<!DOCTYPE html>
<html class="scroll-smooth" lang="tr">
<head>
  <%- include('../partials/head', { title: 'Hakkımda' }) %>
</head>
<body class="bg-background text-on-background font-body-md selection:bg-prestige-gold selection:text-white flex flex-col min-h-screen">
  
  <%- include('../partials/header') %>

  <main class="pt-20 flex-1">
    <!-- Hero / Profile Header -->
    <section class="relative py-section-gap overflow-hidden bg-subtle-pattern">
      <div class="max-w-container-max mx-auto px-gutter relative z-10">
        <div class="max-w-3xl">
          <span class="font-label-caps text-label-caps text-prestige-gold block mb-4">ÖZGEÇMİŞ & VİZYON</span>
          <h1 class="font-display-lg text-display-lg text-legal-navy mb-6">Güvenilir Hukuk Rehberiniz</h1>
          <p class="font-body-lg text-body-lg text-on-surface-variant">
            <%= author?.bio_short || 'Karmaşık hukuki süreçlerinizi stratejik bir bakış açısıyla yönetiyoruz. Her dosyanın kendine özgü hikayesine ve ihtiyacına odaklanıyoruz.' %>
          </p>
        </div>
      </div>
    </section>

    <!-- Detailed Profile Section -->
    <% if (author) { %>
      <section class="py-section-gap bg-white">
        <div class="max-w-container-max mx-auto px-gutter">
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
            <!-- Left Panel (Sidebar Info) -->
            <div class="lg:col-span-4 space-y-8">
              <div class="w-full aspect-[4/5] bg-stone-gray overflow-hidden rounded-lg shadow-lg border border-stone-gray">
                <img src="<%= author.image_url %>" alt="<%= author.full_name %>" class="w-full h-full object-cover">
              </div>

              <!-- Key Credentials -->
              <div class="bg-background p-6 rounded-lg border border-stone-gray space-y-4">
                <h4 class="font-headline-sm text-lg text-legal-navy border-b border-stone-gray/60 pb-2">Hukuki Kimlik</h4>
                <div class="space-y-3 text-sm">
                  <div class="flex justify-between">
                    <span class="text-on-surface-variant">Baro Sicil No:</span>
                    <span class="font-bold text-legal-navy"><%= author.bar_number %></span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-on-surface-variant">Deneyim:</span>
                    <span class="font-bold text-legal-navy"><%= author.experience_years %> Yıl +</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-on-surface-variant">E-Posta:</span>
                    <a href="mailto:<%= author.email %>" class="font-semibold text-prestige-gold hover:underline"><%= author.email %></a>
                  </div>
                </div>
              </div>

              <!-- Specialization Badges -->
              <% if (author.specializations && author.specializations.length > 0) { %>
                <div class="space-y-3">
                  <h4 class="font-label-caps text-xs text-on-surface-variant tracking-wider uppercase">Uzmanlık Alanları</h4>
                  <div class="flex flex-wrap gap-2">
                    <% author.specializations.forEach(spec => { %>
                      <span class="px-3 py-1.5 bg-background border border-stone-gray text-legal-navy text-xs font-semibold rounded">
                        <%= spec %>
                      </span>
                    <% }) %>
                  </div>
                </div>
              <% } %>
            </div>

            <!-- Right Panel (Detailed Bio & Timeline) -->
            <div class="lg:col-span-8 space-y-12">
              <div class="space-y-6">
                <h2 class="font-headline-md text-headline-md text-legal-navy"><%= author.full_name %></h2>
                <div class="font-body-lg text-body-lg text-on-surface-variant space-y-6 leading-relaxed">
                  <%- author.bio_long %>
                </div>
              </div>

              <!-- Certifications & Educations -->
              <% if (certifications && certifications.length > 0) { %>
                <div class="space-y-8">
                  <h3 class="font-headline-sm text-headline-sm text-legal-navy border-b border-stone-gray pb-4">Sertifikalar & Eğitimler</h3>
                  <div class="space-y-6">
                    <% certifications.forEach(cert => { %>
                      <div class="flex gap-4 items-start group">
                        <div class="w-10 h-10 shrink-0 bg-background border border-stone-gray rounded flex items-center justify-center text-prestige-gold group-hover:border-prestige-gold transition-colors">
                          <span class="material-symbols-outlined">workspace_premium</span>
                        </div>
                        <div>
                          <h4 class="font-bold text-legal-navy"><%= cert.title %></h4>
                          <p class="text-sm text-on-surface-variant"><%= cert.issuer %></p>
                          <% if (cert.date_obtained) { %>
                            <span class="text-xs text-stone-gray-600 block mt-1">
                              <%= new Date(cert.date_obtained).toLocaleDateString('tr-TR', { month: 'long', year: 'numeric' }) %>
                            </span>
                          <% } %>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </section>
    <% } %>

    <!-- CTA Section -->
    <section class="bg-legal-navy py-16 text-center text-white">
      <div class="max-w-xl mx-auto px-gutter space-y-6">
        <h3 class="font-headline-md text-headline-md text-prestige-gold">Hukuki Danışmanlığa mı İhtiyacınız Var?</h3>
        <p class="text-stone-gray opacity-80">Uzmanlığımız ve deneyimimizle, karşılaşabileceğiniz tüm yasal problemlerde yanınızdayız.</p>
        <a href="/iletisim" class="inline-block px-10 py-4 bg-prestige-gold text-legal-navy font-bold hover:bg-opacity-90 transition-all uppercase tracking-widest text-sm shadow-xl">
          Bizimle İletişime Geçin
        </a>
      </div>
    </section>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
