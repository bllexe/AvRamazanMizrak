<!DOCTYPE html>
<html class="scroll-smooth" lang="tr">
<head>
  <%- include('../partials/head', { title: article.title, description: article.meta_description }) %>
  <style>
    .article-content blockquote {
      border-left: 4px solid #C5A059;
      padding-left: 24px;
      font-style: italic;
      margin: 40px 0;
      color: #1A2B3C;
      font-size: 1.1em;
    }
    .article-content p {
      margin-bottom: 1.5rem;
      line-height: 1.8;
    }
    .article-content h2 {
      font-family: 'Playfair Display', serif;
      font-size: 1.8rem;
      color: #1A2B3C;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      font-weight: 600;
    }
    .article-content h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
      color: #1A2B3C;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
      font-weight: 600;
    }
    .social-share-floating {
      position: sticky;
      top: 120px;
      height: fit-content;
    }
  </style>
</head>
<body class="bg-background text-on-surface font-body-md selection:bg-prestige-gold selection:text-white flex flex-col min-h-screen">
  
  <%- include('../partials/header') %>

  <main class="mt-20 flex-1">
    <!-- Breadcrumb & Header Section -->
    <section class="pt-12 pb-8 bg-white">
      <div class="max-w-container-max mx-auto px-gutter">
        <nav class="flex items-center space-x-2 text-stone-gray font-label-caps text-label-caps mb-8">
          <a class="hover:text-legal-navy transition-colors" href="/">Anasayfa</a>
          <span class="material-symbols-outlined text-[14px]">chevron_right</span>
          <a class="hover:text-legal-navy transition-colors" href="/makaleler">Makaleler</a>
          <span class="material-symbols-outlined text-[14px]">chevron_right</span>
          <span class="text-legal-navy truncate max-w-[200px] md:max-w-none"><%= article.title %></span>
        </nav>
        <div class="max-w-article-max mx-auto text-center">
          <div class="flex flex-wrap justify-center gap-2 mb-6">
            <% if (article.categories && article.categories.length > 0) { %>
              <% article.categories.forEach(c => { %>
                <span class="inline-block px-3 py-1 bg-surface-container-low text-legal-navy font-label-caps text-label-caps rounded uppercase">
                  <%= c.name %>
                </span>
              <% }) %>
            <% } else { %>
              <span class="inline-block px-3 py-1 bg-surface-container-low text-legal-navy font-label-caps text-label-caps rounded uppercase">
                Genel
              </span>
            <% } %>
          </div>
          <h1 class="font-display-lg text-display-lg text-legal-navy mb-6 leading-tight"><%= article.title %></h1>
          <div class="flex items-center justify-center space-x-6 text-on-surface-variant font-body-md text-body-md">
            <span class="flex items-center gap-2">
              <span class="material-symbols-outlined text-prestige-gold">calendar_today</span> 
              <%= new Date(article.published_at || article.created_at).toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' }) %>
            </span>
            <span class="flex items-center gap-2">
              <span class="material-symbols-outlined text-prestige-gold">schedule</span> 
              <%= article.reading_time_minutes %> Dakika Okuma
            </span>
          </div>
        </div>
      </div>
    </section>



    <!-- Article Content Section -->
    <section class="py-section-gap bg-white relative">
      <div class="max-w-container-max mx-auto px-gutter flex flex-col md:flex-row gap-gutter">
        <!-- Social Share Floating Sidebar -->
        <aside class="hidden md:block w-12 shrink-0">
          <div class="social-share-floating flex flex-col gap-4 items-center">
            <span class="font-label-caps text-[10px] text-stone-gray vertical-text uppercase mb-2" style="writing-mode: vertical-rl;">Paylaş</span>
            <a class="w-10 h-10 flex items-center justify-center border border-stone-gray text-legal-navy hover:bg-legal-navy hover:text-white transition-all" href="https://www.linkedin.com/sharing/share-offsite/?url=<%= encodeURIComponent('http://localhost:3000/makaleler/' + article.slug) %>" target="_blank" title="LinkedIn'de Paylaş">
              <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
              </svg>
            </a>
            <% if (author?.whatsapp_number) { %>
              <a class="w-10 h-10 flex items-center justify-center border border-stone-gray text-legal-navy hover:bg-legal-navy hover:text-white transition-all" href="https://wa.me/<%= author.whatsapp_number.replace(/[^0-9]/g, '') %>?text=<%= encodeURIComponent(article.title + ' http://localhost:3000/makaleler/' + article.slug) %>" target="_blank">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                  <path d="M12.012 2C6.48 2 2 6.48 2 12.012c0 1.764.468 3.42 1.284 4.884L2 22l5.244-1.284C8.688 21.528 10.32 22 12.012 22 17.544 22 22 17.52 22 12.012 22 6.48 17.544 2 12.012 2zm5.724 13.92c-.24.672-1.38 1.308-1.908 1.38-.492.072-.972.108-3.084-.756-2.58-1.056-4.236-3.672-4.368-3.84-.12-.18-1.044-1.392-1.044-2.652s.648-1.884.888-2.124c.24-.24.528-.3.708-.3h.504c.18 0 .42 0 .648.516.228.528.78 1.908.84 2.028.072.12.108.264.024.42-.084.18-.132.276-.264.432-.132.144-.276.324-.396.444-.132.132-.276.276-.12.54.156.264.696 1.152 1.488 1.86.132.12.252.24.372.336.96.804 1.728.996 2.016 1.092.3.108.48.06.66-.144.18-.204.78-.912.984-1.224.204-.3.408-.252.684-.144.276.108 1.752.828 2.052.972.3.156.504.228.576.36.072.132.072.756-.168 1.428z"/>
                </svg>
              </a>
            <% } %>
          </div>
        </aside>

        <!-- Content Area -->
        <article class="flex-1 max-w-article-max mx-auto">
          <div class="article-content font-body-lg text-body-lg text-ink-black leading-relaxed">
            <%- article.content %>
          </div>

          <!-- Author Card -->
          <% if (author) { %>
            <div class="mt-20 p-8 border border-stone-gray bg-background flex flex-col md:flex-row items-center gap-8">
              <div class="w-32 h-32 shrink-0 rounded-full overflow-hidden border-2 border-prestige-gold">
                <img src="<%= author.image_url %>" alt="<%= author.full_name %>" class="w-full h-full object-cover">
              </div>
              <div class="text-center md:text-left">
                <span class="font-label-caps text-label-caps text-prestige-gold mb-2 block">YAZAR</span>
                <h4 class="font-headline-sm text-headline-sm text-legal-navy mb-2"><%= author.full_name %></h4>
                <p class="font-body-md text-body-md text-on-surface-variant">
                  <%= author.bio_short %>
                </p>
                <div class="flex items-center gap-4 mt-4 justify-center md:justify-start">
                  <% if (author.email) { %>
                    <a class="text-legal-navy hover:text-prestige-gold transition-colors flex items-center" href="mailto:<%= author.email %>" title="E-Posta Gönder">
                      <span class="material-symbols-outlined text-[20px]">mail</span>
                    </a>
                  <% } %>
                  <% if (author.linkedin_url) { %>
                    <a class="text-legal-navy hover:text-prestige-gold transition-colors flex items-center" href="<%= author.linkedin_url %>" target="_blank" title="LinkedIn">
                      <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                      </svg>
                    </a>
                  <% } %>
                  <% if (author.twitter_url) { %>
                    <a class="text-legal-navy hover:text-prestige-gold transition-colors flex items-center" href="<%= author.twitter_url %>" target="_blank" title="Twitter / X">
                      <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                      </svg>
                    </a>
                  <% } %>
                  <% if (author.instagram_url) { %>
                    <a class="text-legal-navy hover:text-prestige-gold transition-colors flex items-center" href="<%= author.instagram_url %>" target="_blank" title="Instagram">
                      <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                      </svg>
                    </a>
                  <% } %>
                </div>
              </div>
            </div>
          <% } %>

          <!-- Call to Action -->
          <div class="mt-12 bg-legal-navy p-10 text-center rounded shadow-xl">
            <h3 class="font-headline-md text-headline-md text-white mb-4">Hukuki Yardıma mı İhtiyacınız Var?</h3>
            <p class="text-stone-gray opacity-80 font-body-md mb-8 max-w-md mx-auto">Sorularınız veya randevu talepleriniz için bana ulaşabilirsiniz.</p>
            <a class="inline-block px-10 py-4 bg-prestige-gold text-legal-navy font-bold hover:bg-opacity-90 transition-all uppercase tracking-widest text-sm" href="/iletisim">Randevu Al</a>
          </div>
        </article>
      </div>
    </section>

    <!-- Related Articles -->
    <% if (relatedArticles && relatedArticles.length > 0) { %>
      <section class="py-section-gap bg-background border-t border-stone-gray/30">
        <div class="max-w-container-max mx-auto px-gutter">
          <div class="flex justify-between items-end mb-12">
            <div>
              <span class="font-label-caps text-label-caps text-prestige-gold mb-2 block uppercase">Daha Fazla Oku</span>
              <h2 class="font-headline-md text-headline-md text-legal-navy">İlgili Makaleler</h2>
            </div>
            <a class="hidden md:flex items-center gap-2 text-legal-navy font-bold hover:text-prestige-gold transition-colors" href="/makaleler">
              Tümünü Gör <span class="material-symbols-outlined">arrow_forward</span>
            </a>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <% relatedArticles.forEach(art => { %>
              <a class="group bg-white border border-stone-gray/20 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 rounded overflow-hidden flex flex-col" href="/makaleler/<%= art.slug %>">

                <div class="p-6 flex-1 flex flex-col">
                  <span class="font-label-caps text-label-caps text-prestige-gold mb-3 block uppercase">
                    <%= art.categories && art.categories.length > 0 ? art.categories.map(c => c.name).join(' / ') : 'Genel' %>
                  </span>
                  <h3 class="font-headline-sm text-[20px] text-legal-navy group-hover:text-prestige-gold transition-colors leading-snug mb-4 line-clamp-2"><%= art.title %></h3>
                  <p class="text-on-surface-variant text-body-md line-clamp-2 mb-4 flex-1"><%= art.summary %></p>
                </div>
              </a>
            <% }) %>
          </div>
        </div>
      </section>
    <% } %>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
